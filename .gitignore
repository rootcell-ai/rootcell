# Per-user git identity generated by `rootcell` from host git config.
git-local.nix

# Per-user network params generated by `rootcell` from .env. See network.nix.
network-local.nix

# Per-user env overrides, seeded from .env.defaults on first run.
.env

# Per-user Keychain secret mappings, seeded from secrets.env.defaults.
secrets.env

# Per-user egress allowlists, seeded from proxy/allowed-*.txt.defaults
# on first run. Edit these directly + `./rootcell allow` to hot-reload.
proxy/allowed-https.txt
proxy/allowed-ssh.txt
proxy/allowed-dns.txt

.claude/
node_modules/

# Per-deployment TLS-MITM CA. agent-vm-ca.pem (key+cert) lives only on
# the host and the firewall VM; agent-vm-ca-cert.pem (cert only) is
# also installed in the agent VM trust store. Never commit either —
# the key signs certs that the agent VM blindly trusts.
pki/
