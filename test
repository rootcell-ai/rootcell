#!/usr/bin/env bash
# test — smoke tests for VM provisioning and the egress firewall.
#
# Brings up a separate pair of VMs named `agent-test` and `firewall-test`
# on test-only IPs (.10 firewall, .11 agent of the inter-VM subnet) so it
# never disturbs prod VMs (defaults .2 and .3). Provisions them via
# ./rootcell and runs assertions inside the test agent VM.
#
# Test VMs persist between runs by default — first provision is ~15 min,
# every subsequent run is seconds. Use --clean to force a fresh build (to
# catch first-boot regressions) or --teardown to delete them.
#
# Pi is exercised with `pi --help` only; no LLM call, no Bedrock tokens.
#
# Usage:
#   ./test                # provision (if needed) + run all tests
#   ./test --clean        # delete test VMs first, then provision + run
#   ./test --teardown     # delete test VMs and exit
#
# Exits non-zero if any test fails.

set -euo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# These names + IPs are what make the suite parallel-safe with prod VMs.
# AGENT_VM_NAME / FIREWALL_VM_NAME are read by ./rootcell (see its lines 43-44).
# FIREWALL_IP / AGENT_IP override the network.nix defaults via .env-loader
# precedence. LIMA_NETWORK and NETWORK_PREFIX inherit from .env / defaults.
export AGENT_VM_NAME="agent-test"
export FIREWALL_VM_NAME="firewall-test"
export FIREWALL_IP="192.168.106.10"
export AGENT_IP="192.168.106.11"

# --- arg parse --------------------------------------------------------------
TEARDOWN=0
CLEAN=0
case "${1:-}" in
  --teardown) TEARDOWN=1 ;;
  --clean)    CLEAN=1 ;;
  "") ;;
  *) echo "usage: $0 [--teardown|--clean]" >&2; exit 2 ;;
esac

log() { printf 'test: %s\n' "$*" >&2; }

# --- preflight --------------------------------------------------------------
# Refuse to run if .env (which the user may have customized) has the prod
# VMs claiming our test IPs. Distinct names + distinct IPs are what keep
# us off the prod VMs' toes; this catches the only realistic collision.
if [ -f "$REPO_DIR/.env" ] \
   && grep -Eq "^(FIREWALL_IP=$FIREWALL_IP|AGENT_IP=$AGENT_IP)\$" "$REPO_DIR/.env"; then
  log "your .env already uses the test IPs ($FIREWALL_IP / $AGENT_IP)."
  log "edit .env to use different prod IPs, or run --teardown."
  exit 1
fi

# --- teardown / clean shortcuts --------------------------------------------
if [ "$TEARDOWN" = 1 ]; then
  log "deleting test VMs..."
  limactl delete -f "$AGENT_VM_NAME" "$FIREWALL_VM_NAME" 2>/dev/null || true
  exit 0
fi

if [ "$CLEAN" = 1 ]; then
  log "deleting test VMs for a fresh provision..."
  limactl delete -f "$AGENT_VM_NAME" "$FIREWALL_VM_NAME" 2>/dev/null || true
fi

# --- provision via ./rootcell --------------------------------------------------
log "provisioning test VMs (first run takes ~15 min)..."
"$REPO_DIR/rootcell" provision

sync_default_allowlists() {
  # Force-sync the .defaults allowlists into the test firewall so the
  # test assertions are stable regardless of any host-side allowlist
  # customization. Only touches the test firewall (firewall-test); the
  # host's live files and the prod firewall are untouched.
  log "syncing .defaults allowlists into test firewall..."
  local f
  for f in allowed-https.txt allowed-ssh.txt allowed-dns.txt; do
    limactl cp "$REPO_DIR/proxy/$f.defaults" \
      "$FIREWALL_VM_NAME:/etc/agent-vm/$f"
  done
  limactl shell "$FIREWALL_VM_NAME" -- sudo /etc/agent-vm/reload.sh >/dev/null
}

sync_default_allowlists

# --- harness ----------------------------------------------------------------
PASS=0
FAIL=0
FAILED=()

run() {
  local name="$1"; shift
  local out rc=0
  out=$("$@" 2>&1) || rc=$?
  if [ $rc -eq 0 ]; then
    printf '[PASS] %s\n' "$name"
    PASS=$((PASS + 1))
  else
    printf '[FAIL] %s\n' "$name"
    if [ -n "$out" ]; then
      printf '  %s\n' "${out//$'\n'/$'\n  '}"
    fi
    FAIL=$((FAIL + 1))
    FAILED+=("$name")
  fi
}

agent_sh()    { limactl shell "$AGENT_VM_NAME"    -- bash -lc "$1"; }
firewall_sh() { limactl shell "$FIREWALL_VM_NAME" -- bash -lc "$1"; }

yaml_has_over_vsock() {
  local file="$1"
  awk '
    /^ssh:/ { in_ssh = 1; next }
    in_ssh && /^[^[:space:]#]/ { in_ssh = 0 }
    in_ssh && /^[[:space:]]+overVsock:[[:space:]]+true[[:space:]]*$/ { found = 1 }
    END { exit found ? 0 : 1 }
  ' "$file"
}

lima_instance_has_over_vsock() {
  limactl list "$1" --json | grep -q '"overVsock":true'
}

checked_in_yamls_have_over_vsock() {
  yaml_has_over_vsock "$REPO_DIR/nixos.yaml" \
    && yaml_has_over_vsock "$REPO_DIR/firewall.yaml"
}

agent_restarts_via_wrapper() {
  limactl stop "$AGENT_VM_NAME"
  "$REPO_DIR/rootcell" provision
  sync_default_allowlists
  limactl shell "$AGENT_VM_NAME" -- true
}

log "running tests..."

# --- bucket 1: provisioning -------------------------------------------------
run "checked-in Lima YAMLs force SSH over VSOCK" \
  checked_in_yamls_have_over_vsock

run "agent VM is Running" \
  bash -c "[ \"\$(limactl list --format '{{.Status}}' $AGENT_VM_NAME)\" = Running ]"

run "firewall VM is Running" \
  bash -c "[ \"\$(limactl list --format '{{.Status}}' $FIREWALL_VM_NAME)\" = Running ]"

run "agent Lima config has ssh.overVsock enabled" \
  lima_instance_has_over_vsock "$AGENT_VM_NAME"

run "firewall Lima config has ssh.overVsock enabled" \
  lima_instance_has_over_vsock "$FIREWALL_VM_NAME"

run "agent Lima user has lingering enabled" \
  agent_sh 'loginctl show-user "$USER" -p Linger | grep -q Linger=yes'

run "agent restarts via ./rootcell after locked-down networking" \
  agent_restarts_via_wrapper

run "firewall services active" \
  firewall_sh 'systemctl is-active mitmproxy-explicit mitmproxy-transparent dnsmasq >/dev/null'

run "agent spy --help is wired" \
  "$REPO_DIR/rootcell" spy --help

run "firewall spy formatter installed" \
  firewall_sh 'test -x /etc/agent-vm/agent_spy.py && command -v python3 >/dev/null && test -d /run/agent-vm-spy'

# A static IP on the private socket_vmnet NIC proves the per-VM
# systemd-networkd config from
# agent-vm.nix / firewall-vm.nix actually applied. Stronger signal than
# `hostname`, which Lima can override per-instance.
run "agent VM has test IP on enp0s1" \
  agent_sh "ip -4 -o addr show enp0s1 | grep -q '$AGENT_IP/'"

run "agent VM has no default Lima usernet NIC" \
  agent_sh "! ip link show enp0s2 >/dev/null 2>&1"

run "agent VM routes default traffic through firewall" \
  agent_sh "ip route show default | grep -q '^default via $FIREWALL_IP dev enp0s1'"

run "agent VM has no direct usernet address" \
  agent_sh "! ip -4 -o addr show | grep -q '192\\.168\\.5\\.'"

run "firewall VM has test IP on enp0s2" \
  firewall_sh "ip -4 -o addr show enp0s2 | grep -q '$FIREWALL_IP/'"

run "agent reaches firewall dnsmasq on private VMNET link" \
  agent_sh "dig @$FIREWALL_IP +short +time=5 +tries=1 github.com | grep -qE '^[0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9]+$'"

run "home-manager dev CLIs on PATH" \
  agent_sh 'command -v pi && command -v rg && command -v gh && command -v jq >/dev/null'

# --- bucket 2: pi smoke (no LLM call) ---------------------------------------
run "pi --help runs" \
  agent_sh 'out=$(pi --help) && [ -n "$out" ]'

# --- bucket 3: firewall HTTPS ----------------------------------------------
run "HTTPS allowed: github.com" \
  agent_sh 'code=$(curl -sS --max-time 10 -o /dev/null -w "%{http_code}" https://github.com) && [[ "$code" =~ ^[23] ]]'

# Cleartext HTTP must always fail — the firewall doesn't proxy port 80
# (Host header is unauthenticated, so a port-80 allowlist is theater).
# Even an otherwise-allowed host must not work over plain HTTP. --max-time
# bounds the dropped-packet wait; curl exits non-zero either way.
run "HTTP denied: even allowed host fails over cleartext (github.com:80)" \
  bash -c "! limactl shell $AGENT_VM_NAME -- bash -lc 'curl -sS --max-time 5 -o /dev/null http://github.com' >/dev/null 2>&1"

# example.com isn't in allowed-dns.txt, so dnsmasq returns REFUSED and
# curl never reaches mitmproxy — denial is enforced by DNS, not SNI.
run "HTTPS denied via DNS: example.com (curl fails)" \
  bash -c "! limactl shell $AGENT_VM_NAME -- bash -lc 'curl -sS --max-time 10 -o /dev/null https://example.com' >/dev/null 2>&1"

# pythonhosted.org IS in allowed-dns.txt (suffix match resolves the apex
# too), but allowed-https.txt only lists files.pythonhosted.org — so
# resolution succeeds and the request actually reaches mitmproxy, where
# the SNI allowlist must reject it. This is the test that fails when
# the SNI deny path isn't actually denying.
run "HTTPS denied via SNI: pythonhosted.org (DNS-allowed, SNI-not-allowed)" \
  bash -c "! limactl shell $AGENT_VM_NAME -- bash -lc 'curl -sS --max-time 10 -o /dev/null https://pythonhosted.org' >/dev/null 2>&1"

# Critical: the SNI deny path must fail closed even for clients that
# skip TLS verification. If mitmproxy generates its own cert for a
# denied SNI AND still relays bytes to the real upstream, `curl -k`
# (or any tool that ignores cert errors) silently bypasses the
# allowlist. The previous SNI deny test only catches this regression
# when the client actually validates certs.
deny_sni_no_bypass_with_insecure_curl() {
  # We only care about size_download; curl exiting non-zero is fine
  # (and expected) for a denied connection. Anything > 0 here means
  # mitmproxy relayed real upstream bytes after MITMing the TLS.
  local size
  size=$(limactl shell "$AGENT_VM_NAME" -- bash -lc \
    'curl -sk --max-time 10 -o /dev/null -w "%{size_download}" https://pythonhosted.org' 2>/dev/null) || true
  size=${size:-0}
  if [ "$size" = 0 ]; then
    return 0
  fi
  echo "deny path leaked: curl -k against denied SNI downloaded $size bytes"
  return 1
}
run "HTTPS deny path: insecure curl (-k) yields no upstream bytes" \
  deny_sni_no_bypass_with_insecure_curl

# Companion check: the cert presented to the agent for a denied SNI
# must not be a mitmproxy-issued cert. Mitmproxy issuing a cert at
# all means it terminated TLS — that's the foothold the -k bypass
# exploits. The deny path should reset the connection before the
# server hello, not hand the client a fake cert.
deny_sni_no_mitmproxy_cert() {
  local out
  out=$(limactl shell "$AGENT_VM_NAME" -- bash -lc \
    'curl -skv --max-time 10 -o /dev/null https://pythonhosted.org 2>&1 | grep -i issuer') || true
  if echo "$out" | grep -qi 'mitmproxy'; then
    echo "denied SNI received a mitmproxy-issued cert: $out"
    return 1
  fi
  return 0
}
run "HTTPS deny path: no mitmproxy-issued cert for denied SNI" \
  deny_sni_no_mitmproxy_cert

# With full MITM enabled, the agent VM's curl must accept mitmproxy-
# minted certs for allowed hosts WITHOUT --insecure. This proves that
# (a) our CA cert is in the agent VM's system trust store, and (b)
# mitmproxy is actually intercepting (not passthrough). A passthrough-
# era github.com test would also pass without -k, so we strengthen the
# signal by additionally checking the cert issuer is our CA.
allowed_https_cert_is_ours() {
  local issuer
  issuer=$(limactl shell "$AGENT_VM_NAME" -- bash -lc \
    'curl -sSv --max-time 10 -o /dev/null https://github.com 2>&1 | grep -i "issuer:" | head -n1') || true
  if echo "$issuer" | grep -q "agent-vm proxy CA"; then
    return 0
  fi
  echo "expected mitmproxy-minted cert (issuer=agent-vm proxy CA), got: $issuer"
  return 1
}
run "HTTPS allowed: cert issuer is our deployment CA (proves MITM is on)" \
  allowed_https_cert_is_ours

# The whole point of MITM: a client that sends an allowlisted SNI but
# routes the TCP to a non-allowlisted IP must fail. Without MITM
# (passthrough), `curl -k` against `--resolve allowed.com:443:evil.ip`
# would happily complete the TLS handshake to evil.ip presenting its
# own cert. With MITM, mitmproxy connects to the original destination
# and validates the upstream cert against the allowed SNI; evil.ip can't
# produce a valid cert, so mitmproxy must fail before relaying upstream
# bytes. A mitmproxy-generated 502 for "hostname mismatch" is acceptable;
# an upstream response is not. We use 1.1.1.1 as the "evil" IP — it's
# reachable (DNS-bypassed), serves TLS, but its cert is for
# *.cloudflare-dns.com, not github.com.
sni_pinned_to_upstream_identity() {
  local out
  out=$(limactl shell "$AGENT_VM_NAME" -- bash -lc \
    'curl -sk --max-time 10 -D - \
       --resolve github.com:443:1.1.1.1 https://github.com' 2>/dev/null) || true
  if [ -z "$out" ]; then
    return 0
  fi
  if echo "$out" | grep -qi '^server: mitmproxy' \
     && echo "$out" | grep -qi 'Certificate verify failed: hostname mismatch'; then
    return 0
  fi
  echo "MITM bypass: SNI=github.com routed to 1.1.1.1 returned unexpected response:"
  printf '%s\n' "$out" | head -20
  return 1
}
run "HTTPS MITM: SNI-vs-upstream-IP mismatch denied" \
  sni_pinned_to_upstream_identity

# Companion check at the HTTP layer: open TLS with allowlisted SNI to
# the legitimate upstream, but send a Host header for a different
# (also-allowlisted) host. Some shared-infra exfil channels rely on
# routing by Host on the upstream — even if both names are allowed,
# Host must agree with SNI or we let cross-tenant requests through.
host_must_agree_with_sni() {
  # api.github.com is the SNI/connect target; Host header overridden to
  # objects.githubusercontent.com (also in allowed-https.txt). A 4xx
  # body or any download means the firewall accepted the mismatch.
  local code
  code=$(limactl shell "$AGENT_VM_NAME" -- bash -lc \
    'curl -sS --max-time 10 -o /dev/null -w "%{http_code}" \
       -H "Host: objects.githubusercontent.com" \
       https://api.github.com/' 2>/dev/null) || true
  # On deny, mitmproxy kills the flow → curl gets RST → http_code=000.
  if [ "$code" = "000" ] || [ -z "$code" ]; then
    return 0
  fi
  echo "Host/SNI mismatch leaked: got HTTP $code from api.github.com with Host: objects.githubusercontent.com"
  return 1
}
run "HTTPS MITM: Host header must agree with SNI" \
  host_must_agree_with_sni

# --- bucket 4: firewall DNS -------------------------------------------------
run "DNS allowed: github.com resolves to an IP" \
  agent_sh 'dig +short +time=5 +tries=1 github.com | grep -qE "^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$"'

# Per proxy/reload.sh, the deny path returns REFUSED (no catch-all in
# dnsmasq), not 0.0.0.0.
run "DNS denied: example.com returns REFUSED" \
  agent_sh 'dig example.com +time=5 +tries=1 2>&1 | grep -q "status: REFUSED"'

# --- bucket 5: firewall SSH -------------------------------------------------
# Any of the three matched strings means the SSH banner negotiated
# successfully, which proves CONNECT got through mitmproxy and the SSH
# handshake reached the upstream host.
run "SSH allowed: github.com (CONNECT succeeds)" \
  agent_sh 'ssh -o BatchMode=yes -o StrictHostKeyChecking=no -o ConnectTimeout=15 -T git@github.com 2>&1 | grep -qE "(successfully authenticated|Permission denied|does not provide shell)"'

# 1.1.1.1 avoids the DNS allowlist entirely (no name resolution needed).
# CONNECT host is 1.1.1.1:22, which doesn't match anything in
# proxy/allowed-ssh.txt, so mitmproxy kills the flow.
run "SSH denied: 1.1.1.1 (ssh fails)" \
  bash -c "! limactl shell $AGENT_VM_NAME -- bash -lc 'ssh -o BatchMode=yes -o ConnectTimeout=10 -T -p 22 root@1.1.1.1' >/dev/null 2>&1"

# --- final report -----------------------------------------------------------
printf '\n'
printf 'Results: %d passed, %d failed\n' "$PASS" "$FAIL"
if [ "$FAIL" -gt 0 ]; then
  printf 'Failed:\n'
  for name in "${FAILED[@]}"; do printf '  - %s\n' "$name"; done
  exit 1
fi
