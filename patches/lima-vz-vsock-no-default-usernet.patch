+const disableDefaultUsernetForVsockEnv = "LIMA_DISABLE_DEFAULT_USERNET_FOR_VSOCK"
+
+func useSSHOverVsock(inst *limatype.Instance) bool {
+	useSSHOverVsock := *inst.Config.OS == limatype.LINUX
+	if inst.Config.SSH.OverVsock != nil {
+		useSSHOverVsock = *inst.Config.SSH.OverVsock
+	}
+	return useSSHOverVsock
+}
+
+func disableDefaultUsernetForVsock(inst *limatype.Instance) bool {
+	if !useSSHOverVsock(inst) {
+		return false
+	}
+	if limayaml.FirstUsernetIndex(inst.Config) != -1 {
+		return false
+	}
+	return os.Getenv(disableDefaultUsernetForVsockEnv) == inst.Name
+}
