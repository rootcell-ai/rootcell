+func (m *virtualMachineWrapper) waitAndStartVsockForwarder(ctx context.Context, vsockPort uint32, hostAddress string) error {
+	ticker := time.NewTicker(500 * time.Millisecond)
+	defer ticker.Stop()
+
+	var lastErr error
+	for {
+		if err := m.startVsockForwarder(ctx, vsockPort, hostAddress); err == nil {
+			return nil
+		} else {
+			lastErr = err
+		}
+		select {
+		case <-ctx.Done():
+			return fmt.Errorf("timed out waiting for vsock:%d on VM: %w", vsockPort, lastErr)
+		case <-ticker.C:
+		}
+	}
+}
