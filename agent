#!/usr/bin/env bash
# agent — self-bootstrapping wrapper around two Lima VMs.
#
# Two VMs:
#   - firewall  — tiny appliance running mitmproxy + dnsmasq, brokers all
#                 egress for the agent VM.
#   - agent     — where the coding agent (pi.dev) actually runs. Has only
#                 a private link to the firewall; no other internet path.
#
# On every invocation:
#   1. Reads the AWS Bedrock API key from macOS Keychain.
#   2. Ensures the firewall VM exists, is running, and is provisioned.
#      Syncs the allowlist files into it and reloads.
#   3. Waits for the firewall's mitmproxy + dnsmasq to be listening.
#   4. Ensures the agent VM exists, is running, and is provisioned.
#   5. Execs into the agent VM with the key in the env.
#
# HTTPS/HTTP egress from the agent VM is filtered transparently — there
# are no proxy env vars to set, the firewall VM intercepts via NAT. SSH
# uses an explicit ProxyCommand (configured in home.nix) so it can be
# allowlisted by hostname.
#
# Daily use: `./agent pi`, `./agent`, `./agent -- nix flake update`, etc.
#
# Subcommands:
#   ./agent provision     # re-copy files and re-rebuild both VMs
#   ./agent allow         # hot-reload allowlists into the running firewall
#                         #   (use after editing proxy/allowed-*.txt)
#
# One-time host setup (the script prints the exact commands the first time
# something's missing — these are listed here for reference):
#   nix build .#socket_vmnet                         # builds the helper from this flake
#   sudo install -m 0755 -d /opt/socket_vmnet/bin    # see ensure_socket_vmnet for the full
#   sudo install -m 0755 result/bin/* /opt/socket_vmnet/bin/   # install command (one-time)
#   limactl sudoers | sudo tee /private/etc/sudoers.d/lima
#   security add-generic-password -a "$USER" -s aws-bedrock-api-key -w "sk-..."
#   chmod +x ./agent

set -euo pipefail

# --- Configuration ----------------------------------------------------------
REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
AGENT_VM="agent"
FIREWALL_VM="firewall"
GUEST_USER="luser"
GUEST_REPO_DIR="/home/${GUEST_USER}/lima-pi-vm"

# Files copied into each VM for `nixos-rebuild --flake`. Both VMs share
# flake.nix + common.nix + network.nix + the per-user network-local.nix
# generated below from .env. Each VM pulls in only its own role module
# via the flake output it builds.
AGENT_NIX_FILES=(flake.nix common.nix agent-vm.nix home.nix
                 git-local.nix network.nix network-local.nix pi)
FIREWALL_NIX_FILES=(flake.nix common.nix firewall-vm.nix
                    network.nix network-local.nix proxy)

log() { printf 'agent: %s\n' "$*" >&2; }

# --- Subcommand parsing -----------------------------------------------------
SUBCMD=""
case "${1:-}" in
  provision) SUBCMD=provision; shift ;;
  allow)     SUBCMD=allow; shift ;;
esac

# --- 0. Seed and load .env --------------------------------------------------
if [ ! -f "$REPO_DIR/.env" ] && [ -f "$REPO_DIR/.env.defaults" ]; then
  cp "$REPO_DIR/.env.defaults" "$REPO_DIR/.env"
  log "seeded .env from .env.defaults"
fi
if [ -f "$REPO_DIR/.env" ]; then
  set -a
  # shellcheck disable=SC1091
  . "$REPO_DIR/.env"
  set +a
fi

# Apply defaults for any network var the user didn't set in .env. These
# match the defaults in network.nix so a stale .env still works.
LIMA_NETWORK="${LIMA_NETWORK:-host}"
FIREWALL_IP="${FIREWALL_IP:-192.168.106.1}"
AGENT_IP="${AGENT_IP:-192.168.106.2}"
NETWORK_PREFIX="${NETWORK_PREFIX:-24}"

# Generate network-local.nix from the resolved values. Mirrors how
# git-local.nix is generated. The file is gitignored; defaults in
# network.nix apply if it's absent.
{
  echo "# Generated by ./agent from .env. DO NOT EDIT — change .env instead."
  echo "{"
  printf '  firewallIp    = "%s";\n' "$FIREWALL_IP"
  printf '  agentIp       = "%s";\n' "$AGENT_IP"
  printf '  networkPrefix = %s;\n'   "$NETWORK_PREFIX"
  printf '  limaNetwork   = "%s";\n' "$LIMA_NETWORK"
  echo "}"
} > "$REPO_DIR/network-local.nix"

# --- 1a. Preflight: socket_vmnet -------------------------------------------
# Lima's `lima: host` network needs the socket_vmnet helper at a root-owned
# path so its sudoers grant has a stable, secure target. socket_vmnet isn't
# in nixpkgs, so this repo packages it (pkgs/socket_vmnet.nix) and exposes
# it as `nix build .#socket_vmnet`. The binary itself is therefore Nix-
# managed (immutable, root-owned in the store, byte-for-byte reproducible),
# but macOS won't let any non-root tool write under /opt — that's the
# single imperative step in the whole setup. The script builds, compares,
# and prints a `sudo install` command if /opt/socket_vmnet is missing or
# stale; you copy-paste, re-run, done.
SOCKET_VMNET_DST=/opt/socket_vmnet/bin/socket_vmnet

ensure_socket_vmnet() {
  local out
  out=$(nix build --no-link --print-out-paths "$REPO_DIR#socket_vmnet" 2>&1) || {
    log "failed to build socket_vmnet from $REPO_DIR/pkgs/socket_vmnet.nix:"
    printf '%s\n' "$out" >&2
    exit 1
  }
  local nix_bin="$out/bin/socket_vmnet"

  if [ -x "$SOCKET_VMNET_DST" ] && cmp -s "$nix_bin" "$SOCKET_VMNET_DST"; then
    return 0
  fi

  cat >&2 <<EOF
agent: socket_vmnet not installed (or out of date) at /opt/socket_vmnet.

Why this needs sudo: Lima's sudoers grant references the binary by path,
and macOS won't accept a sudoers rule for a user-writable location. The
binary itself is built declaratively from this repo's flake (see
pkgs/socket_vmnet.nix); the path below is in the Nix store and is
root-owned and immutable. The only imperative step is the copy under
/opt, which has to be sudo on macOS.

Run:

  sudo install -m 0755 -d /opt/socket_vmnet/bin
  sudo install -m 0755 \\
    $out/bin/socket_vmnet \\
    $out/bin/socket_vmnet_client \\
    /opt/socket_vmnet/bin/

Then re-run ./agent.
EOF
  exit 1
}

ensure_socket_vmnet

# --- 1b. Preflight: lima sudoers -------------------------------------------
# Once /opt/socket_vmnet/bin/socket_vmnet exists, Lima can generate the
# sudoers grant that lets it invoke socket_vmnet without prompting per VM.
if [ ! -f /private/etc/sudoers.d/lima ]; then
  cat >&2 <<'EOF'
agent: one-time host setup needed before first run.

Lima's `lima: host` shared network needs a sudoers entry so socket_vmnet
can manage the inter-VM network without prompting. Run:

  limactl sudoers | sudo tee /private/etc/sudoers.d/lima

Then re-run ./agent.
EOF
  exit 1
fi

# --- 2. Helpers -------------------------------------------------------------
# Returns 0 if the VM was already running or was just started from Stopped.
# Returns 1 if the VM was newly created (caller must force a provision).
#
# Both YAMLs (nixos.yaml and firewall.yaml) put the `lima: <name>` entry at
# index 0 of `networks:` — the firewall's internet egress is the implicit
# Apple Virtio NAT that vmType: vz provides for free, not a separate
# entry. We patch index 0 at create time to match $LIMA_NETWORK from .env
# so the checked-in YAML works for any user-customized network name.
ensure_vm_running() {
  local name="$1" config="$2"
  local status
  status=$(limactl list --format '{{.Status}}' "$name" 2>/dev/null || true)
  case "$status" in
    Running) return 0 ;;
    Stopped) log "starting $name VM..."; limactl start "$name"; return 0 ;;
    "")
      log "$name VM not found — creating (~3-5 min for image + boot)..."
      # Wrap in `if` so the call-site `|| force_provision=1` (which masks
      # function returns) doesn't also mask a real limactl failure here.
      if ! limactl start --tty=false --name="$name" \
            --set ".user.name = \"$GUEST_USER\"" \
            --set ".networks[0].lima = \"$LIMA_NETWORK\"" \
            "$config"; then
        log "limactl start $name failed; aborting."
        exit 1
      fi
      return 1
      ;;
    *) log "$name VM in unexpected state: '$status'. Aborting."; exit 1 ;;
  esac
}

# Copy a file/dir list into the VM at $GUEST_REPO_DIR.
copy_repo_into_vm() {
  local vm="$1"; shift
  local files=("$@")
  limactl shell "$vm" -- mkdir -p "$GUEST_REPO_DIR"
  local copy_args=()
  local f
  for f in "${files[@]}"; do
    copy_args+=("$REPO_DIR/$f")
  done
  copy_args+=("$vm:$GUEST_REPO_DIR/")
  limactl cp -r "${copy_args[@]}"
}

# Generate git-local.nix from the host's git config so commits inside the
# agent VM are attributed to the user. Regenerated on every provision.
write_git_local_nix() {
  local git_user_name git_user_email
  git_user_name=$(git config --global user.name 2>/dev/null || true)
  git_user_email=$(git config --global user.email 2>/dev/null || true)
  {
    echo "{"
    [ -n "$git_user_name" ] && \
      printf '  programs.git.settings.user.name  = "%s";\n' "$git_user_name"
    [ -n "$git_user_email" ] && \
      printf '  programs.git.settings.user.email = "%s";\n' "$git_user_email"
    echo "}"
  } > "$REPO_DIR/git-local.nix"
}

# Block until $vm is listening on $host:$port for $proto (tcp|udp).
wait_for_listener() {
  local vm="$1" host="$2" proto="$3" port="$4"
  local flag i
  if [ "$proto" = tcp ]; then flag="-tln"; else flag="-uln"; fi
  for i in $(seq 1 60); do
    if limactl shell "$vm" -- ss "$flag" 2>/dev/null \
         | awk '{print $5}' | grep -q "^${host}:${port}$"; then
      return 0
    fi
    sleep 1
  done
  log "timeout waiting for $vm to listen on $proto $host:$port"
  limactl shell "$vm" -- journalctl --no-pager -n 50 \
    -u mitmproxy-explicit -u mitmproxy-transparent -u dnsmasq >&2
  exit 1
}

# Sync allowlist files into the firewall VM and trigger a reload.
sync_allowlists() {
  local f
  for f in proxy/allowed-https.txt proxy/allowed-ssh.txt proxy/allowed-dns.txt; do
    limactl cp "$REPO_DIR/$f" "$FIREWALL_VM:/etc/agent-vm/$(basename "$f")"
  done
  limactl shell "$FIREWALL_VM" -- sudo /etc/agent-vm/reload.sh
}

# --- Subcommand: allow ------------------------------------------------------
# Hot-reload only — assumes both VMs are already up.
if [ "$SUBCMD" = allow ]; then
  status=$(limactl list --format '{{.Status}}' "$FIREWALL_VM" 2>/dev/null || true)
  if [ "$status" != Running ]; then
    log "firewall VM not running; start it with ./agent first."
    exit 1
  fi
  sync_allowlists
  log "allowlists reloaded."
  exit 0
fi

# --- 3. Bring up the firewall VM and provision it --------------------------
force_firewall=0
[ "$SUBCMD" = provision ] && force_firewall=1
ensure_vm_running "$FIREWALL_VM" "$REPO_DIR/firewall.yaml" || force_firewall=1

needs_firewall_provision=$force_firewall
if [ "$needs_firewall_provision" -eq 0 ]; then
  if ! limactl shell "$FIREWALL_VM" -- bash -lc \
        'systemctl is-active mitmproxy-explicit >/dev/null 2>&1 \
         && systemctl is-active mitmproxy-transparent >/dev/null 2>&1 \
         && systemctl is-active dnsmasq >/dev/null 2>&1' 2>/dev/null; then
    needs_firewall_provision=1
  fi
fi

if [ "$needs_firewall_provision" -eq 1 ]; then
  log "provisioning firewall VM (first run takes ~5 min)..."
  write_git_local_nix
  copy_repo_into_vm "$FIREWALL_VM" "${FIREWALL_NIX_FILES[@]}"
  limactl shell "$FIREWALL_VM" -- bash -lc "
    set -e
    cd '$GUEST_REPO_DIR'
    sudo nixos-rebuild switch --flake .#firewall-vm
  "
  log "firewall provisioning complete."
fi

# Sync allowlists every time so edits to proxy/allowed-*.txt take effect
# even on a plain ./agent invocation. Cheap (a few small file copies).
sync_allowlists
wait_for_listener "$FIREWALL_VM" "$FIREWALL_IP" tcp 8080  # mitmproxy explicit (SSH)
wait_for_listener "$FIREWALL_VM" "$FIREWALL_IP" tcp 8081  # mitmproxy transparent (HTTPS)
wait_for_listener "$FIREWALL_VM" "$FIREWALL_IP" udp 53    # dnsmasq

# --- 4. Bring up the agent VM and provision it -----------------------------
force_agent=0
[ "$SUBCMD" = provision ] && force_agent=1
ensure_vm_running "$AGENT_VM" "$REPO_DIR/nixos.yaml" || force_agent=1

needs_agent_provision=$force_agent
if [ "$needs_agent_provision" -eq 0 ]; then
  if ! limactl shell "$AGENT_VM" -- \
       bash -lc 'command -v pi >/dev/null 2>&1' 2>/dev/null; then
    needs_agent_provision=1
  fi
fi

if [ "$needs_agent_provision" -eq 1 ]; then
  log "provisioning agent VM (first run takes ~10 min: nixpkgs fetch via firewall)..."
  write_git_local_nix
  copy_repo_into_vm "$AGENT_VM" "${AGENT_NIX_FILES[@]}"

  # The firewall VM is up with nftables NAT REDIRECT for TCP/80 and TCP/443,
  # so the agent VM's first nixos-rebuild reaches cache.nixos.org through
  # the transparent mitmproxy with no in-VM config needed. After the
  # rebuild applies, the only network path is via the firewall (lima0),
  # which is the steady state.
  limactl shell "$AGENT_VM" -- bash -lc "
    set -e
    cd '$GUEST_REPO_DIR'
    sudo nixos-rebuild switch --flake .#agent-vm
    nix run nixpkgs#home-manager -- switch --flake .#$GUEST_USER
  "
  log "agent provisioning complete."
fi

if [ "$SUBCMD" = provision ]; then
  log "done."
  exit 0
fi

# --- 5. Read the API key from Keychain -------------------------------------
key=$(security find-generic-password -s aws-bedrock-api-key -w 2>/dev/null) || {
  cat >&2 <<'EOF'
agent: AWS Bedrock API key not found in macOS Keychain.

Add it with:
  security add-generic-password -a "$USER" -s aws-bedrock-api-key -w "sk-..."

Then re-run.
EOF
  exit 1
}

# --- 6. Exec into the agent VM ---------------------------------------------
if [ "$#" -eq 0 ]; then
  set -- bash -l
fi

exec limactl shell "$AGENT_VM" \
  env \
  AWS_BEARER_TOKEN_BEDROCK="$key" \
  AWS_REGION="${AWS_REGION:-us-east-1}" \
  "$@"
