#!/usr/bin/env bash
# agent — self-bootstrapping wrapper around two Lima VMs.
#
# Two VMs:
#   - firewall  — tiny appliance running mitmproxy + dnsmasq, brokers all
#                 egress for the agent VM.
#   - agent     — where the coding agent (pi.dev) actually runs. Has only
#                 a private link to the firewall; no other internet path.
#
# On every invocation:
#   1. Reads the AWS Bedrock API key from macOS Keychain.
#   2. Ensures the firewall VM exists, is running, and is provisioned.
#      Syncs the allowlist files into it and reloads.
#   3. Waits for the firewall's mitmproxy + dnsmasq to be listening.
#   4. Ensures the agent VM exists, is running, and is provisioned.
#   5. Execs into the agent VM with the key in the env.
#
# HTTPS/HTTP egress from the agent VM is filtered transparently — there
# are no proxy env vars to set, the firewall VM intercepts via NAT. SSH
# uses an explicit ProxyCommand (configured in home.nix) so it can be
# allowlisted by hostname.
#
# Daily use: `./agent pi`, `./agent`, `./agent -- nix flake update`, etc.
#
# Subcommands:
#   ./agent provision     # re-copy files and re-rebuild both VMs
#   ./agent allow         # hot-reload allowlists into the running firewall
#                         #   (use after editing proxy/allowed-*.txt)
#   ./agent pubkey        # print the agent VM's SSH public key
#
# One-time host setup (the script prints the exact commands the first time
# something's missing — these are listed here for reference):
#   nix build .#socket_vmnet                         # builds the helper from this flake
#   sudo install -m 0755 -d /opt/socket_vmnet/bin    # see ensure_socket_vmnet for the full
#   sudo install -m 0755 result/bin/* /opt/socket_vmnet/bin/   # install command (one-time)
#   limactl sudoers | sudo tee /private/etc/sudoers.d/lima
#   security add-generic-password -a "$USER" -s aws-bedrock-api-key -w "sk-..."
#   chmod +x ./agent

set -euo pipefail

# --- Configuration ----------------------------------------------------------
resolve_script_dir() {
  local source dir
  source="${BASH_SOURCE[0]}"

  while [ -L "$source" ]; do
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    [[ "$source" == /* ]] || source="$dir/$source"
  done

  cd -P "$(dirname "$source")" && pwd
}

REPO_DIR="$(resolve_script_dir)"
AGENT_VM="${AGENT_VM_NAME:-agent}"
FIREWALL_VM="${FIREWALL_VM_NAME:-firewall}"
GUEST_USER="luser"
GUEST_REPO_DIR="/home/${GUEST_USER}/lima-pi-vm"

# Files copied into each VM for `nixos-rebuild --flake`. Both VMs share
# flake.nix + common.nix + network.nix + the per-user network-local.nix
# generated below from .env. Each VM pulls in only its own role module
# via the flake output it builds.
AGENT_NIX_FILES=(flake.nix common.nix agent-vm.nix home.nix
                 git-local.nix network.nix network-local.nix pi
                 pki/agent-vm-ca-cert.pem)
FIREWALL_NIX_FILES=(flake.nix common.nix firewall-vm.nix
                    network.nix network-local.nix proxy)

log() { printf 'agent: %s\n' "$*" >&2; }

LIMACTL_BIN="${LIMACTL:-}"
ensure_lima() {
  [ -n "$LIMACTL_BIN" ] && return 0

  local out err
  err=$(mktemp)
  if ! out=$(nix build --no-link --print-out-paths "$REPO_DIR#lima" 2>"$err"); then
    log "failed to build repo-patched Lima from $REPO_DIR/flake.nix:"
    sed 's/^/agent:   /' "$err" >&2
    rm -f "$err"
    exit 1
  fi
  rm -f "$err"
  LIMACTL_BIN="$out/bin/limactl"
}

limactl() {
  ensure_lima
  LIMA_DISABLE_DEFAULT_USERNET_FOR_VSOCK="$AGENT_VM" "$LIMACTL_BIN" "$@"
}

# --- Subcommand parsing -----------------------------------------------------
SUBCMD=""
case "${1:-}" in
  provision) SUBCMD=provision; shift ;;
  allow)     SUBCMD=allow; shift ;;
  pubkey)    SUBCMD=pubkey; shift ;;
esac

# --- 0. Seed and load .env, seed allowlists --------------------------------
if [ ! -f "$REPO_DIR/.env" ] && [ -f "$REPO_DIR/.env.defaults" ]; then
  cp "$REPO_DIR/.env.defaults" "$REPO_DIR/.env"
  log "seeded .env from .env.defaults"
fi

# Seed the egress allowlists from their .defaults siblings on first run.
# The live files (proxy/allowed-*.txt) are gitignored so users can edit
# them freely without git noise; the .defaults versions are the canonical
# starting point in source control.
for _f in allowed-https.txt allowed-ssh.txt allowed-dns.txt; do
  if [ ! -f "$REPO_DIR/proxy/$_f" ] && [ -f "$REPO_DIR/proxy/$_f.defaults" ]; then
    cp "$REPO_DIR/proxy/$_f.defaults" "$REPO_DIR/proxy/$_f"
    log "seeded proxy/$_f from $_f.defaults"
  fi
done
unset _f

if [ -f "$REPO_DIR/.env" ]; then
  # Pre-existing env vars win over .env, so callers (e.g. ./test) can
  # override the network/VM names per invocation without rewriting .env.
  while IFS='=' read -r k v; do
    [[ -z "$k" || "${k:0:1}" == "#" ]] && continue
    [[ -n "${!k+x}" ]] && continue
    export "$k=$v"
  done < "$REPO_DIR/.env"
fi

# Apply defaults for any network var the user didn't set in .env. These
# match the defaults in network.nix so a stale .env still works.
LIMA_NETWORK="${LIMA_NETWORK:-host}"
FIREWALL_IP="${FIREWALL_IP:-192.168.106.2}"
AGENT_IP="${AGENT_IP:-192.168.106.3}"
NETWORK_PREFIX="${NETWORK_PREFIX:-24}"
VM_START_TIMEOUT="${VM_START_TIMEOUT:-180s}"

# Generate network-local.nix from the resolved values. Mirrors how
# git-local.nix is generated. The file is gitignored; defaults in
# network.nix apply if it's absent.
{
  echo "# Generated by ./agent from .env. DO NOT EDIT — change .env instead."
  echo "{"
  printf '  firewallIp    = "%s";\n' "$FIREWALL_IP"
  printf '  agentIp       = "%s";\n' "$AGENT_IP"
  printf '  networkPrefix = %s;\n'   "$NETWORK_PREFIX"
  printf '  limaNetwork   = "%s";\n' "$LIMA_NETWORK"
  echo "}"
} > "$REPO_DIR/network-local.nix"

# --- Subcommand: pubkey ----------------------------------------------------
# Read-only dump of the agent VM's SSH public key. Placed before the
# socket_vmnet / sudoers preflights so a stale host setup doesn't block
# this from working — `limactl shell` against a running VM doesn't need
# either. The key is generated on first provision by home-manager (see
# home.nix `generateAgentVmSshKey`) and stays stable across re-provisions.
if [ "$SUBCMD" = pubkey ]; then
  status=$(limactl list --format '{{.Status}}' "$AGENT_VM" 2>/dev/null || true)
  if [ "$status" != Running ]; then
    log "agent VM not running; start it with ./agent first."
    exit 1
  fi
  if ! limactl shell "$AGENT_VM" -- test -f "/home/$GUEST_USER/.ssh/id_rsa.pub" 2>/dev/null; then
    log "no SSH key in agent VM yet; run ./agent provision first."
    exit 1
  fi
  exec limactl shell "$AGENT_VM" -- cat "/home/$GUEST_USER/.ssh/id_rsa.pub"
fi

# --- 1a. Preflight: socket_vmnet -------------------------------------------
# Lima's `lima: host` network needs the socket_vmnet helper at a root-owned
# path so its sudoers grant has a stable, secure target. socket_vmnet isn't
# in nixpkgs, so this repo packages it (pkgs/socket_vmnet.nix) and exposes
# it as `nix build .#socket_vmnet`. The binary itself is therefore Nix-
# managed (immutable, root-owned in the store, byte-for-byte reproducible),
# but macOS won't let any non-root tool write under /opt — that's the
# single imperative step in the whole setup. The script builds, compares,
# and prints a `sudo install` command if /opt/socket_vmnet is missing or
# stale; you copy-paste, re-run, done.
SOCKET_VMNET_DST=/opt/socket_vmnet/bin/socket_vmnet

ensure_socket_vmnet() {
  local out err
  err=$(mktemp)
  out=$(nix build --no-link --print-out-paths "$REPO_DIR#socket_vmnet" 2>"$err") || {
    log "failed to build socket_vmnet from $REPO_DIR/pkgs/socket_vmnet.nix:"
    cat "$err" >&2
    rm -f "$err"
    exit 1
  }
  cat "$err" >&2
  rm -f "$err"
  local nix_bin="$out/bin/socket_vmnet"

  if [ -x "$SOCKET_VMNET_DST" ] && cmp -s "$nix_bin" "$SOCKET_VMNET_DST"; then
    return 0
  fi

  cat >&2 <<EOF
agent: socket_vmnet not installed (or out of date) at /opt/socket_vmnet.

Why this needs sudo: Lima's sudoers grant references the binary by path,
and macOS won't accept a sudoers rule for a user-writable location. The
binary itself is built declaratively from this repo's flake (see
pkgs/socket_vmnet.nix); the path below is in the Nix store and is
root-owned and immutable. The only imperative step is the copy under
/opt, which has to be sudo on macOS.

Run:

  sudo install -m 0755 -d /opt/socket_vmnet/bin
  sudo install -m 0755 \\
    $out/bin/socket_vmnet \\
    $out/bin/socket_vmnet_client \\
    /opt/socket_vmnet/bin/

Then re-run ./agent.
EOF
  exit 1
}

ensure_socket_vmnet

# --- 1b. Preflight: lima sudoers -------------------------------------------
# Once /opt/socket_vmnet/bin/socket_vmnet exists, Lima can generate the
# sudoers grant that lets it invoke socket_vmnet without prompting per VM.
if [ ! -f /private/etc/sudoers.d/lima ]; then
  cat >&2 <<'EOF'
agent: one-time host setup needed before first run.

Lima's `lima: host` shared network needs a sudoers entry so socket_vmnet
can manage the inter-VM network without prompting. Run:

  limactl sudoers | sudo tee /private/etc/sudoers.d/lima

Then re-run ./agent.
EOF
  exit 1
fi

# --- 2. Helpers -------------------------------------------------------------
# Return a Lima VM status, or an empty string if the VM does not exist.
vm_status() {
  limactl list --format '{{.Status}}' "$1" 2>/dev/null || true
}

socket_vmnet_pidfile() {
  printf '/private/var/run/lima/%s_socket_vmnet.pid' "$LIMA_NETWORK"
}

socket_vmnet_socket() {
  printf '/private/var/run/lima/socket_vmnet.%s' "$LIMA_NETWORK"
}

socket_vmnet_is_stale() {
  local sock pidfile pid
  sock=$(socket_vmnet_socket)
  pidfile=$(socket_vmnet_pidfile)

  # No socket means no daemon has been started for this network yet.
  [ -e "$sock" ] || return 1

  # A socket with no pidfile, or a pidfile whose process is gone, leaves
  # running VMs with broken VZ<->VMNET pipes until they reconnect.
  [ -f "$pidfile" ] || return 0
  pid=$(cat "$pidfile" 2>/dev/null || true)
  [ -n "$pid" ] || return 0
  if ps -p "$pid" >/dev/null 2>&1; then
    return 1
  fi
  return 0
}

force_stop_if_running() {
  local name="$1" status
  status=$(vm_status "$name")
  if [ "$status" = Running ]; then
    log "force-stopping $name VM to repair stale $LIMA_NETWORK socket_vmnet network..."
    limactl stop --force "$name"
  fi
}

repair_stale_socket_vmnet() {
  if ! socket_vmnet_is_stale; then
    return 0
  fi

  log "stale socket_vmnet daemon detected for Lima network '$LIMA_NETWORK'."
  log "restarting affected VMs one at a time so Lima recreates the VMNET pipe."
  force_stop_if_running "$AGENT_VM"
  force_stop_if_running "$FIREWALL_VM"
}

diagnose_start_failure() {
  local name="$1" log_file="$HOME/.lima/$name/ha.stderr.log" tail_out=""
  [ -f "$log_file" ] && tail_out=$(tail -80 "$log_file" 2>/dev/null || true)

  if echo "$tail_out" | grep -q 'Waiting for port to become available on .*:22' \
     && ! echo "$tail_out" | grep -q 'Started vsock forwarder'; then
    log "$name VM did not establish Lima SSH over VSOCK."
    log "Lima is waiting for guest TCP/22 on its default usernet path."
    log "The agent VM should be started with this repo's patched Lima, which"
    log "skips that usernet NIC and polls VSOCK directly for SSH."
  fi
}

start_vm() {
  local name="$1"
  if limactl start --timeout "$VM_START_TIMEOUT" "$name"; then
    return 0
  fi
  diagnose_start_failure "$name"
  exit 1
}

# Returns 0 if the VM was already running or was just started from Stopped.
# Returns 1 if the VM was newly created (caller must force a provision).
#
# Both YAMLs (nixos.yaml and firewall.yaml) put the `lima: <name>` entry at
# index 0 of `networks:` — the firewall's internet egress is the implicit
# Apple Virtio NAT that vmType: vz provides for free, not a separate
# entry. We patch index 0 at create time to match $LIMA_NETWORK from .env
# so the checked-in YAML works for any user-customized network name.
ensure_vm_running() {
  local name="$1" config="$2"
  local status
  status=$(vm_status "$name")
  case "$status" in
    Running) return 0 ;;
    Stopped)
      log "starting $name VM..."
      start_vm "$name"
      return 0
      ;;
    "")
      log "$name VM not found — creating (~3-5 min for image + boot)..."
      # Wrap in `if` so the call-site `|| force_provision=1` (which masks
      # function returns) doesn't also mask a real limactl failure here.
      if ! limactl start --timeout "$VM_START_TIMEOUT" --tty=false --name="$name" \
            --set ".user.name = \"$GUEST_USER\"" \
            --set ".networks[0].lima = \"$LIMA_NETWORK\"" \
            --set ".ssh.overVsock = true" \
            "$config"; then
        diagnose_start_failure "$name"
        log "limactl start $name failed; aborting."
        exit 1
      fi
      return 1
      ;;
    *) log "$name VM in unexpected state: '$status'. Aborting."; exit 1 ;;
  esac
}

bootstrap_agent_firewall_route() {
  limactl shell "$AGENT_VM" -- sudo bash -lc "
    set -euo pipefail
    iface=enp0s1
    if [ -e /sys/class/net/enp0s2 ]; then
      iface=enp0s2
    fi
    # The nixos-lima base image runs dhcpcd before our NixOS generation is
    # active. Stop it so it cannot remove the temporary default route while
    # the first nixos-rebuild is fetching nixpkgs through the firewall.
    systemctl stop dhcpcd.service 2>/dev/null || true
    ip link set \"\$iface\" up
    ip addr flush dev \"\$iface\"
    ip addr add '$AGENT_IP/$NETWORK_PREFIX' dev \"\$iface\"
    ip route replace default via '$FIREWALL_IP' dev \"\$iface\"
    if command -v resolvectl >/dev/null 2>&1; then
      resolvectl dns \"\$iface\" '$FIREWALL_IP' || true
      resolvectl domain \"\$iface\" '~.' || true
    fi
    printf 'nameserver %s\n' '$FIREWALL_IP' > /etc/resolv.conf
  "
}

bootstrap_agent_firewall_trust() {
  limactl shell "$AGENT_VM" -- bash -lc "
    set -euo pipefail
    cert='$GUEST_REPO_DIR/pki/agent-vm-ca-cert.pem'
    bundle=/tmp/agent-vm-bootstrap-ca-bundle.crt
    if [ -r /etc/ssl/certs/ca-certificates.crt ]; then
      cat /etc/ssl/certs/ca-certificates.crt \"\$cert\" > \"\$bundle\"
    else
      cp \"\$cert\" \"\$bundle\"
    fi
    chmod 0644 \"\$bundle\"
  "
}

# Copy a file/dir list into the VM at $GUEST_REPO_DIR.
copy_repo_into_vm() {
  local vm="$1"; shift
  local files=("$@")
  limactl shell "$vm" -- mkdir -p "$GUEST_REPO_DIR"
  local f parent
  for f in "${files[@]}"; do
    parent=$(dirname "$f")
    [ "$parent" = "." ] && parent=
    limactl shell "$vm" -- mkdir -p "$GUEST_REPO_DIR/$parent"
    limactl cp -r "$REPO_DIR/$f" "$vm:$GUEST_REPO_DIR/$parent/"
  done
}

# Generate git-local.nix from the host's git config so commits inside the
# agent VM are attributed to the user. Regenerated on every provision.
write_git_local_nix() {
  local git_user_name git_user_email
  git_user_name=$(git config --global user.name 2>/dev/null || true)
  git_user_email=$(git config --global user.email 2>/dev/null || true)
  {
    echo "{"
    [ -n "$git_user_name" ] && \
      printf '  programs.git.settings.user.name  = "%s";\n' "$git_user_name"
    [ -n "$git_user_email" ] && \
      printf '  programs.git.settings.user.email = "%s";\n' "$git_user_email"
    echo "}"
  } > "$REPO_DIR/git-local.nix"
}

# Block until the firewall VM is listening on tcp/8080, tcp/8081, and
# udp/53. All three checks happen inside one limactl shell call (every
# limactl shell costs ~1s of SSH startup, which adds up if you make ~180
# of them like the previous per-port version did).
wait_for_firewall_listeners() {
  # mitmproxy binds 0.0.0.0:{8080,8081} (see firewall-vm.nix for why);
  # dnsmasq binds firewallIp:53 via bind-dynamic. Match by ":port " so
  # we don't depend on which IP a service settled on. Trailing space
  # avoids accidentally matching :80 inside :8080 or :853 etc.
  # ss --no-header so we don't have to skip the column titles, then awk
  # column 4 (Local Address:Port) and grep for the port we want. Same
  # column for both tcp and udp.
  local probe='
    for _ in $(seq 1 300); do
      if ss -tlnH | awk "{print \$4}" | grep -qE ":8080$" \
         && ss -tlnH | awk "{print \$4}" | grep -qE ":8081$" \
         && ss -ulnH | awk "{print \$4}" | grep -qE ":53$"; then
        exit 0
      fi
      sleep 0.2
    done
    exit 1
  '
  if ! limactl shell "$FIREWALL_VM" -- bash -c "$probe" 2>/dev/null; then
    log "timeout waiting for firewall services"
    limactl shell "$FIREWALL_VM" -- journalctl --no-pager -n 50 \
      -u mitmproxy-explicit -u mitmproxy-transparent -u dnsmasq >&2
    exit 1
  fi
}

# Sync allowlist files into the firewall VM and trigger a reload.
sync_allowlists() {
  local f
  for f in proxy/allowed-https.txt proxy/allowed-ssh.txt proxy/allowed-dns.txt; do
    limactl cp "$REPO_DIR/$f" "$FIREWALL_VM:/etc/agent-vm/$(basename "$f")"
  done
  limactl shell "$FIREWALL_VM" -- sudo /etc/agent-vm/reload.sh
}

# Generate the TLS-MITM CA on the host the first time it's missing.
# Persisted under pki/ (gitignored). The agent VM's nix trust store
# embeds the cert (so curl/git/openssl in the guest accept the
# mitmproxy-minted per-host certs); the firewall VM's mitmproxy uses
# the combined key+cert pem to mint and sign those certs on the fly.
#
# Three files come out:
#   pki/agent-vm-ca.key       — RSA 2048 private key, 0600
#   pki/agent-vm-ca-cert.pem  — X.509 cert (the trust anchor), 0644
#   pki/agent-vm-ca.pem       — key + cert concatenated, 0600
#                                (mitmproxy reads its CA from a single
#                                pem containing both)
#
# 10-year validity. The CA is per-deployment (per-host, per-clone of
# this repo); regenerate by deleting pki/.
ensure_ca() {
  local dir="$REPO_DIR/pki"
  local key="$dir/agent-vm-ca.key"
  local crt="$dir/agent-vm-ca-cert.pem"
  local pem="$dir/agent-vm-ca.pem"

  if [ -f "$key" ] && [ -f "$crt" ] && [ -f "$pem" ]; then
    return 0
  fi

  log "generating TLS-MITM CA in pki/ (one-time, persists across runs)"
  mkdir -p "$dir"
  chmod 0700 "$dir"

  # Self-signed CA. -nodes = don't encrypt the key (mitmproxy needs it
  # readable at startup; the firewall VM is the only place it lands).
  # Constraints + key usage make this a "real" CA in the technical
  # sense — some clients (e.g. recent Go stdlib) reject as a CA any
  # cert without basicConstraints CA:TRUE.
  openssl req -x509 -newkey rsa:2048 -nodes \
    -keyout "$key" -out "$crt" -days 3650 \
    -subj "/CN=agent-vm proxy CA" \
    -addext "basicConstraints=critical,CA:TRUE,pathlen:0" \
    -addext "keyUsage=critical,keyCertSign,cRLSign" \
    >/dev/null 2>&1

  # mitmproxy expects key+cert in one file at confdir/mitmproxy-ca.pem.
  cat "$key" "$crt" > "$pem"

  chmod 0600 "$key" "$pem"
  chmod 0644 "$crt"
}

# Push the CA's key+cert into the firewall VM at /etc/agent-vm/, with
# strict perms (0600 root:root). limactl cp connects as the unprivileged
# Lima user, so we stage in /tmp and then sudo-install to flip the
# owner. ExecStartPre in firewall-vm.nix copies it from /etc into the
# mitmproxy services' RuntimeDirectory at start.
sync_firewall_ca() {
  local pem="$REPO_DIR/pki/agent-vm-ca.pem"
  limactl cp "$pem" "$FIREWALL_VM:/tmp/.agent-vm-ca.pem.staged"
  limactl shell "$FIREWALL_VM" -- sudo install -m 0600 -o root -g root \
    /tmp/.agent-vm-ca.pem.staged /etc/agent-vm/agent-vm-ca.pem
  limactl shell "$FIREWALL_VM" -- rm -f /tmp/.agent-vm-ca.pem.staged
}

# --- Subcommand: allow ------------------------------------------------------
# Hot-reload only — assumes both VMs are already up.
if [ "$SUBCMD" = allow ]; then
  status=$(limactl list --format '{{.Status}}' "$FIREWALL_VM" 2>/dev/null || true)
  if [ "$status" != Running ]; then
    log "firewall VM not running; start it with ./agent first."
    exit 1
  fi
  sync_allowlists
  log "allowlists reloaded."
  exit 0
fi

# Repair a known bad state where the socket file remains but the backing
# socket_vmnet process has died. In that state Lima can still report the VMs
# as Running, but the agent cannot reach the firewall VM's DNS/proxy ports.
repair_stale_socket_vmnet

# --- 3. Bring up the firewall VM and provision it --------------------------
force_firewall=0
[ "$SUBCMD" = provision ] && force_firewall=1
ensure_vm_running "$FIREWALL_VM" "$REPO_DIR/firewall.yaml" || force_firewall=1

needs_firewall_provision=$force_firewall
if [ "$needs_firewall_provision" -eq 0 ]; then
  if ! limactl shell "$FIREWALL_VM" -- bash -lc \
        'systemctl is-active mitmproxy-explicit >/dev/null 2>&1 \
         && systemctl is-active mitmproxy-transparent >/dev/null 2>&1 \
         && systemctl is-active dnsmasq >/dev/null 2>&1' 2>/dev/null; then
    needs_firewall_provision=1
  fi
fi

if [ "$needs_firewall_provision" -eq 1 ]; then
  log "provisioning firewall VM (first run takes ~5 min)..."
  write_git_local_nix
  ensure_ca
  copy_repo_into_vm "$FIREWALL_VM" "${FIREWALL_NIX_FILES[@]}"
  limactl shell "$FIREWALL_VM" -- bash -lc "
    set -e
    cd '$GUEST_REPO_DIR'
    sudo nixos-rebuild switch --flake .#firewall-vm
  "
  # The mitmproxy services have ConditionPathExists=/etc/agent-vm/agent-vm-ca.pem
  # so on the very first nixos-rebuild they're skipped (their CA is absent);
  # we push the CA, then start them. On subsequent provisions the file is
  # already there and nixos-rebuild restarts them itself, but pushing again
  # is idempotent (and catches the case where the host's pki/ was rotated).
  sync_firewall_ca
  limactl shell "$FIREWALL_VM" -- sudo systemctl restart \
    mitmproxy-explicit mitmproxy-transparent
  log "firewall provisioning complete."
fi

# Sync allowlists every time so edits to proxy/allowed-*.txt take effect
# even on a plain ./agent invocation. Cheap (a few small file copies).
ensure_ca
sync_allowlists
wait_for_firewall_listeners

# --- 4. Bring up the agent VM and provision it -----------------------------
force_agent=0
[ "$SUBCMD" = provision ] && force_agent=1
ensure_vm_running "$AGENT_VM" "$REPO_DIR/nixos.yaml" || force_agent=1

needs_agent_provision=$force_agent
if [ "$needs_agent_provision" -eq 0 ]; then
  if ! limactl shell "$AGENT_VM" -- \
       bash -lc 'command -v pi >/dev/null 2>&1' 2>/dev/null; then
    needs_agent_provision=1
  fi
fi

if [ "$needs_agent_provision" -eq 1 ]; then
  log "provisioning agent VM (first run takes ~10 min: nixpkgs fetch via firewall)..."
  write_git_local_nix
  copy_repo_into_vm "$AGENT_VM" "${AGENT_NIX_FILES[@]}"

  # The patched Lima launcher gives the agent VM only the private VMNET NIC.
  # Before the new NixOS generation is active, install a temporary route and
  # resolver so the first nixos-rebuild already fetches through the firewall.
  # The base image has not imported our MITM CA yet, so build a temporary CA
  # bundle for the bootstrap Nix commands. agent-vm.nix installs the same CA
  # into the system trust store for steady state.
  bootstrap_agent_firewall_route
  bootstrap_agent_firewall_trust
  limactl shell "$AGENT_VM" -- bash -lc "
    set -e
    cd '$GUEST_REPO_DIR'
    export NIX_SSL_CERT_FILE=/tmp/agent-vm-bootstrap-ca-bundle.crt
    export SSL_CERT_FILE=/tmp/agent-vm-bootstrap-ca-bundle.crt
    export GIT_SSL_CAINFO=/tmp/agent-vm-bootstrap-ca-bundle.crt
    export REQUESTS_CA_BUNDLE=/tmp/agent-vm-bootstrap-ca-bundle.crt
    sudo env \
      NIX_SSL_CERT_FILE=\"\$NIX_SSL_CERT_FILE\" \
      SSL_CERT_FILE=\"\$SSL_CERT_FILE\" \
      GIT_SSL_CAINFO=\"\$GIT_SSL_CAINFO\" \
      REQUESTS_CA_BUNDLE=\"\$REQUESTS_CA_BUNDLE\" \
      nixos-rebuild switch --flake .#agent-vm
    nix run nixpkgs#home-manager -- switch --flake .#$GUEST_USER
  "
  log "agent provisioning complete."

  # Surface the per-VM SSH pubkey so the user can register it on GitHub.
  # home-manager activation generates it on first run and leaves it alone
  # afterward (see home.nix `generateAgentVmSshKey`), so re-provisions
  # print the same key — handy as a reminder, not noise.
  pubkey=$(limactl shell "$AGENT_VM" -- cat "/home/$GUEST_USER/.ssh/id_rsa.pub")
  cat >&2 <<EOF

agent: this VM's SSH public key (register at https://github.com/settings/keys
to enable \`git push git@github.com:...\` from inside the VM):

$pubkey

Run \`./agent pubkey\` to print it again.

EOF
fi

if [ "$SUBCMD" = provision ]; then
  log "done."
  exit 0
fi

# --- 5. Read the API key from Keychain -------------------------------------
key=$(security find-generic-password -s aws-bedrock-api-key -w 2>/dev/null) || {
  cat >&2 <<'EOF'
agent: AWS Bedrock API key not found in macOS Keychain.

Add it with:
  security add-generic-password -a "$USER" -s aws-bedrock-api-key -w "sk-..."

Then re-run.
EOF
  exit 1
}

# --- 6. Exec into the agent VM ---------------------------------------------
if [ "$#" -eq 0 ]; then
  set -- bash -l
fi

# NODE_EXTRA_CA_CERTS / SSL_CERT_FILE / REQUESTS_CA_BUNDLE are also set
# via agent-vm.nix's environment.variables, but `limactl shell <vm> cmd`
# runs over ssh as a non-login shell that doesn't source /etc/profile.
# Pass them explicitly so Node-based agents (pi, claude code, codex)
# trust the mitmproxy-minted certs without --insecure dances. The
# bundle path is the NixOS system trust anchor, which our CA is
# inserted into via security.pki.certificateFiles.
exec limactl shell "$AGENT_VM" \
  env \
  AWS_BEARER_TOKEN_BEDROCK="$key" \
  AWS_REGION="${AWS_REGION:-us-east-1}" \
  NODE_EXTRA_CA_CERTS=/etc/ssl/certs/ca-certificates.crt \
  SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt \
  REQUESTS_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt \
  "$@"
